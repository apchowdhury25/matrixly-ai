# Matrixly SupportForge — copy to .env and fill in (never commit .env)

# --- Required for smart AI mode (optional for demo/FAQ-only) ---
XAI_API_KEY=
XAI_MODEL=grok-4-1-fast-reasoning
XAI_BASE_URL=https://api.x.ai/v1

# --- API security ---
# Admin + ingest endpoints
SUPPORTFORGE_API_KEY=change-me-admin-key
# Public widget key (chat only; treat as semi-public site key)
SUPPORTFORGE_WIDGET_KEY=pk_live_change-me

# Comma-separated browser origins allowed for the widget
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8787,https://matrixbazaar.com,https://www.matrixbazaar.com

# HITL: always | external_only | off  (off = local demo only)
HITL_MODE=external_only
HITL_AUTO_APPROVE=false

# --- Business ---
BUSINESS_NAME=Matrixly Demo Store
SUPPORT_EMAIL=support@example.com
TIMEZONE=America/Chicago

# --- Optional: Email (Gmail API or IMAP) ---
EMAIL_BACKEND=none
# EMAIL_BACKEND=imap
# EMAIL_IMAP_HOST=imap.hostinger.com
# EMAIL_IMAP_PORT=993
# EMAIL_IMAP_USER=
# EMAIL_IMAP_PASSWORD=
# EMAIL_BACKEND=gmail
# GMAIL_CREDENTIALS_PATH=credentials.json
# GMAIL_TOKEN_PATH=token.json

# --- Optional: Notion knowledge sync ---
# NOTION_API_KEY=
# NOTION_DATABASE_ID=

# --- Optional: Zendesk-style tickets ---
# ZENDESK_SUBDOMAIN=
# ZENDESK_EMAIL=
# ZENDESK_API_TOKEN=

# --- Cost estimates (USD per 1M tokens) ---
COST_INPUT_PER_1M=5.0
COST_OUTPUT_PER_1M=15.0
