# Matrixly BookWise — copy to .env (never commit .env)

XAI_API_KEY=
XAI_MODEL=grok-4-1-fast-reasoning
XAI_BASE_URL=https://api.x.ai/v1

BOOKWISE_API_KEY=change-me-admin-key
BOOKWISE_WIDGET_KEY=pk_live_change-me

CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8790,https://matrixly.world,https://www.matrixly.world,https://matrixbazaar.com,https://www.matrixbazaar.com

HITL_MODE=external_only
HITL_AUTO_APPROVE=false

BUSINESS_NAME=Matrixly Demo Clinic
SUPPORT_EMAIL=bookings@example.com
TIMEZONE=America/Chicago

# Calendar backend: local | google | calendly
CALENDAR_BACKEND=local

# Google Calendar (optional)
# GOOGLE_CALENDAR_ID=primary
# GOOGLE_CREDENTIALS_PATH=credentials.json
# GOOGLE_TOKEN_PATH=token.json

# Calendly-style API (optional)
# CALENDLY_API_TOKEN=
# CALENDLY_EVENT_TYPE_URI=

# Cost estimates USD per 1M tokens
COST_INPUT_PER_1M=5.0
COST_OUTPUT_PER_1M=15.0
